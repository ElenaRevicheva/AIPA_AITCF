# Copy to .env (never commit .env). Token: https://hashnode.com/settings/developer
HASHNODE_ACCESS_TOKEN=
#
# Publication ID (required if API lists zero publications):
#   Open your *blog* dashboard on Hashnode (not only Profile). The publication id
#   appears in the dashboard URL as a 24-char hex string, e.g. 65d99cd9447d15d98a2fc264
#   (see Hashnode: "Publishing with a custom editing interface" — copy from dashboard URL.)
# Your blog URL is typically: https://YOUR_USERNAME.hashnode.dev  (username: aideazz → aideazz.hashnode.dev)
HASHNODE_PUBLICATION_ID=
# Optional: if you have several blogs — subdomain on *.hashnode.dev (e.g. aideazz)
HASHNODE_SUBDOMAIN=aideazz
# Optional overrides for publish script
# HASHNODE_POST_TITLE=
# HASHNODE_POST_MARKDOWN=

# --- Daily auto-generated articles (src/hashnode-daily.ts + cron in cto-aipa.ts) ---
# HASHNODE_DAILY_ENABLED=true
# Default: 09:30 every day, Panama City (UTC−5, no DST)
# HASHNODE_DAILY_CRON=30 9 * * *
# HASHNODE_DAILY_TZ=America/Panama
# HASHNODE_DAILY_PUBLIC=true
# HASHNODE_ARTICLE_MODEL=claude-sonnet-4-20250514
# HASHNODE_DAILY_TRIGGER_SECRET=random-secret-for-POST-/hashnode/daily-run
# HASHNODE_TOPIC_STATE_DIR=/path/to/persist  (default: ./data on server)
#
# Optional Telegram ping when a daily post publishes (same bot as CTO AIPA)
# TELEGRAM_HASHNODE_NOTIFY_CHAT_ID=5481526862

# Public base URL (nginx HTTPS → PM2; see docs/oracle/CTO_AIPA_PUBLIC_HTTPS.md)
# CTO_AIPA_PUBLIC_URL=https://webhook.aideazz.xyz/cto

# --- Phase 3: aideazz.xyz contact / UTM → Oracle (POST /marketing/inquiry) ---
# Server-side or edge proxy only — never expose MARKETING_INQUIRY_SECRET in the browser.
# MARKETING_INQUIRY_SECRET=long-random-string
# Optional extra CORS origins (comma-separated) for static preview domains
# MARKETING_CORS_ORIGINS=https://preview.example.com
#
# Weekly Telegram digest of inbound leads (Monday 09:00 UTC by default)
# TELEGRAM_LEADS_DIGEST_CHAT_ID=5481526862
# MARKETING_LEADS_DIGEST_CRON=0 9 * * 1
# MARKETING_LEADS_DIGEST_TZ=UTC
# MARKETING_LEADS_DIGEST_ENABLED=false
# Public site form (aideazz) — disable browser endpoint if needed
# MARKETING_INQUIRY_PROXY_ENABLED=false
# MARKETING_INQUIRY_PROXY_MAX_PER_WINDOW=12
#
# Inquiry emails (Resend — https://resend.com/api-keys)
# Two emails per submission (when domain + sender are verified in Resend):
#   1) Team: MARKETING_INQUIRY_NOTIFY_TO (default aipa@aideazz.xyz)
#   2) Client confirmation: submitter’s email (set MARKETING_INQUIRY_SEND_CONFIRMATION=false to disable)
# RESEND_API_KEY=re_xxxx
# (alias) RESEND_KEY=re_xxxx
# MARKETING_INQUIRY_NOTIFY_TO=aipa@aideazz.xyz
# Production (verified aideazz.xyz in Resend — same pattern as VibeJobHunter):
# MARKETING_INQUIRY_FROM=AIdeazz <aipa@aideazz.xyz>
# MARKETING_INQUIRY_SEND_CONFIRMATION=false
#
# Google reCAPTCHA v3 (invisible) — pair with aideazz VITE_RECAPTCHA_SITE_KEY in build
# RECAPTCHA_SECRET_KEY=
# RECAPTCHA_MIN_SCORE=0.35
