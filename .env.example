# Copy to .env (never commit .env). Token: https://hashnode.com/settings/developer
HASHNODE_ACCESS_TOKEN=
#
# Publication ID (required if API lists zero publications):
#   Open your *blog* dashboard on Hashnode (not only Profile). The publication id
#   appears in the dashboard URL as a 24-char hex string, e.g. 65d99cd9447d15d98a2fc264
#   (see Hashnode: "Publishing with a custom editing interface" — copy from dashboard URL.)
# Your blog URL is typically: https://YOUR_USERNAME.hashnode.dev  (username: aideazz → aideazz.hashnode.dev)
HASHNODE_PUBLICATION_ID=
# Optional: if you have several blogs — subdomain on *.hashnode.dev (e.g. aideazz)
HASHNODE_SUBDOMAIN=aideazz
# Must match the publication your token publishes to and aideazz VITE_HASHNODE_HOST (default aideazz.hashnode.dev)
# HASHNODE_HOST=aideazz.hashnode.dev
# Optional: public GraphQL wait (after publish, before Dev.to) — same API as portfolio
# HASHNODE_FEED_WAIT_ATTEMPTS=15
# HASHNODE_FEED_WAIT_MS=4000
# Optional overrides for publish script
# HASHNODE_POST_TITLE=
# HASHNODE_POST_MARKDOWN=

# --- Daily auto-generated articles (src/hashnode-daily.ts + cron in cto-aipa.ts) ---
# HASHNODE_DAILY_ENABLED=true
# Default: 14:30 (2:30 PM) every day, Panama City (UTC−5, no DST)
# HASHNODE_DAILY_CRON=30 14 * * *
# HASHNODE_DAILY_TZ=America/Panama
# Listed in Hashnode public feed (required for aideazz.xyz/blog GraphQL sync). Default: listed.
# Set HASHNODE_DAILY_DELISTED=true (or HASHNODE_DAILY_PUBLIC=false) only for stealth tests — URLs may 404 for visitors.
# HASHNODE_DAILY_PUBLIC=true
# HASHNODE_DAILY_DELISTED=false
# Optional: override blog base for Telegram links (default https://aideazz.xyz)
# AIDEAZZ_SITE_URL=https://aideazz.xyz
# HASHNODE_ARTICLE_MODEL=claude-sonnet-4-20250514
# HASHNODE_DAILY_TRIGGER_SECRET=random-secret-for-POST-/hashnode/daily-run
# HASHNODE_TOPIC_STATE_DIR=/path/to/persist  (default: ./data on server)
#
# Optional Telegram ping when a daily post publishes (same bot as CTO AIPA).
# Uses TELEGRAM_HASHNODE_NOTIFY_CHAT_ID, or falls back to TELEGRAM_LEADS_DIGEST_CHAT_ID if unset.
# TELEGRAM_HASHNODE_NOTIFY_CHAT_ID=5481526862

# Public base URL (nginx HTTPS → PM2; see docs/oracle/CTO_AIPA_PUBLIC_HTTPS.md)
# CTO_AIPA_PUBLIC_URL=https://webhook.aideazz.xyz/cto

# --- Phase 3: aideazz.xyz contact / UTM → Oracle (POST /marketing/inquiry) ---
# Server-side or edge proxy only — never expose MARKETING_INQUIRY_SECRET in the browser.
# MARKETING_INQUIRY_SECRET=long-random-string
# Optional extra CORS origins (comma-separated) for static preview domains
# MARKETING_CORS_ORIGINS=https://preview.example.com
#
# Weekly Telegram digest of inbound leads (Monday 09:00 UTC by default)
# TELEGRAM_LEADS_DIGEST_CHAT_ID=5481526862
# MARKETING_LEADS_DIGEST_CRON=0 9 * * 1
# MARKETING_LEADS_DIGEST_TZ=UTC
# MARKETING_LEADS_DIGEST_ENABLED=false
# Public site form (aideazz) — disable browser endpoint if needed
# MARKETING_INQUIRY_PROXY_ENABLED=false
# MARKETING_INQUIRY_PROXY_MAX_PER_WINDOW=12
#
# Inquiry emails (Resend — https://resend.com/api-keys)
# Two emails per submission (when domain + sender are verified in Resend):
#   1) Team: MARKETING_INQUIRY_NOTIFY_TO (default aipa@aideazz.xyz)
#   2) Client confirmation: submitter’s email (set MARKETING_INQUIRY_SEND_CONFIRMATION=false to disable)
# RESEND_API_KEY=re_xxxx
# (alias) RESEND_KEY=re_xxxx
# MARKETING_INQUIRY_NOTIFY_TO=aipa@aideazz.xyz
# Production (verified aideazz.xyz in Resend — same pattern as VibeJobHunter):
# MARKETING_INQUIRY_FROM=AIdeazz <aipa@aideazz.xyz>
# MARKETING_INQUIRY_SEND_CONFIRMATION=false
#
# Google reCAPTCHA v3 (invisible) — pair with aideazz VITE_RECAPTCHA_SITE_KEY in build
# RECAPTCHA_SECRET_KEY=
# RECAPTCHA_MIN_SCORE=0.1
# Optional: send client IP to Google (default off — nginx X-Forwarded-For can break checks)
# RECAPTCHA_SEND_REMOTEIP=true
#
# If keys are managed in Google Cloud (reCAPTCHA Enterprise), set all three — server uses Enterprise API:
# RECAPTCHA_ENTERPRISE_PROJECT_ID=   # must match Cloud Console URL (?project=...)
# RECAPTCHA_ENTERPRISE_API_KEY=
# RECAPTCHA_SITE_KEY=               # same site key as the frontend
#
# --- Phase 4: Founder Outreach Pipeline (/outreach/*) ---
# Bearer token for all /outreach/* endpoints
# OUTREACH_SECRET=random-long-string
# Sender address (uses MARKETING_INQUIRY_FROM or aideazz.xyz default if unset)
# OUTREACH_FROM=AIdeazz <elena@aideazz.xyz>
# Daily email cap (default 10)
# OUTREACH_DAILY_CAP=10
# Claude model for email generation
# OUTREACH_MODEL=claude-sonnet-4-20250514
# Hunter.io — free tier: 25 searches + 50 verifications / month
# HUNTER_API_KEY=
#
# --- Phase 4b: Prospect Ingestion (YC companies → Hunter → Oracle) ---
# Path to YC company JSON (produced by job-list-filter cron)
# YC_JSON_PATH=/home/ubuntu/job-list-filter/yc_ai_assistant_companies.json
# Monthly Hunter.io call budget (free tier = 25)
# HUNTER_MONTHLY_BUDGET=25
# Ingestion cron (default 2 PM Panama — 1 hour before outreach send at 3 PM)
# INGEST_CRON=0 14 * * *
# INGEST_TZ=America/Panama
#
# --- Phase 4c: Google Places → outreach_targets (src/prospect-places.ts) ---
# Enable "Places API (New)" in Google Cloud Console for the same project as the key.
# Text Search (New): POST https://places.googleapis.com/v1/places:searchText
# GOOGLE_PLACES_API_KEY=
# Optional: ISO region (PA = Panama), language, map bias so local results rank correctly
# GOOGLE_PLACES_REGION=PA
# GOOGLE_PLACES_LANGUAGE=en
# Optional circle bias (e.g. Panama City): lat, lng, radius in meters (max 50000)
# GOOGLE_PLACES_BIAS_LAT=8.9824
# GOOGLE_PLACES_BIAS_LNG=-79.5199
# GOOGLE_PLACES_BIAS_RADIUS_M=50000
# HTTP: POST /outreach/ingest-places { city, industry, maxResults?, clientContext?, regionCode? } — Bearer OUTREACH_SECRET
# Telegram: /places_ingest <industry> <city>
#
# --- Phase 4d: Document → outreach (src/doc-ingest.ts) — RFP / takeoff / call logs → Hunter → outreach_targets ---
# Uses ANTHROPIC_API_KEY + HUNTER_API_KEY (same as Phase 4). No extra env.
# HTTP: POST /outreach/ingest-doc { text, docType?, clientContext?, maxProspects? } — Bearer OUTREACH_SECRET
# Telegram: /doc_ingest <optional doc label> then paste document text in the same or follow-up message
#
# --- Phase 5: Lead Triage (src/lead-triage.ts) ---
# Required: ANTHROPIC_API_KEY (Claude Haiku fallback + Sonnet refine; triage will not run without it)
# Recommended: GROQ_API_KEY (cheap bulk classify; if unset, every lead uses Haiku)
# GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# Optional: LEAD_TRIAGE_SECRET — protects POST /leads/triage-run and GET /leads/dashboard?secret=
# When set: opening /leads/dashboard without ?secret= shows an HTML unlock form (same key).
# LEAD_TRIAGE_SECRET=
# GET /leads/triage-status — JSON: groq, anthropic, ready, cron (no secrets)
# Daily brief to Telegram after triage cron (optional):
# TELEGRAM_LEADS_DIGEST_CHAT_ID=
# TRIAGE_CRON=0 8 * * *
# TRIAGE_MAX_BUSINESS_LEADS=20
# TRIAGE_MAX_OUTREACH=10
# TRIAGE_INTER_LEAD_DELAY_MS=350
# TRIAGE_FALLBACK_MODEL=claude-3-5-haiku-20241022
#
# GitHub webhook code review (POST /webhook/github): Groq 429 must not crash PM2 — falls back to Haiku
# CODE_REVIEW_FALLBACK_MODEL=claude-3-5-haiku-20241022
#
# --- Atuona /visualize video (src/atuona-creative-ai.ts) — priority: Luma Direct → Replicate Luma → Runway ---
# REPLICATE_API_TOKEN=              # required for Flux + Luma-on-Replicate fallback when LUMA_API_KEY fails
# Optional: Replicate Luma model (default luma/ray-2-720p; old luma/dream-machine is retired on Replicate)
# REPLICATE_LUMA_MODEL=luma/ray-2-720p
# LUMA_API_KEY=                     # Luma Labs Direct API (primary video)
# LUMA_VIDEO_RESOLUTION=1080p       # 540p | 720p | 1080p | 4k
# RUNWAY_API_KEY=                   # final fallback (Gen-4.5 image_to_video)
