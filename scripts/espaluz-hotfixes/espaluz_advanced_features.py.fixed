def get_housing_help(country: str) -> str:
    """Get housing/apartment information for a country."""
    country_lower = country.lower().replace(' ', '_')
    
    if country_lower not in HOUSING_LISTINGS:
        # Default response for countries without specific data
        return f"""🏠 *HOUSING HELP*

For {country.title()}, I recommend:

📱 *Search Websites:*
• Facebook Marketplace
• Local real estate websites
• Expat Facebook groups

📝 *Key Phrases:*
• "Busco apartamento" = I'm looking for an apartment
• "¿Cuánto es el alquiler?" = How much is the rent?
• "¿Incluye servicios?" = Are utilities included?

💡 Ask locals for neighborhood recommendations!
"""
    
    data = HOUSING_LISTINGS[country_lower]
    
    response = f"🏠 *APARTMENT HUNTING - {country.upper()}*\n\n"
    
    # Popular areas
    response += "📍 *Popular Areas:*\n"
    for area in data['areas'][:6]:
        response += f"• {area}\n"
    
    # Average rent
    response += "\n💰 *Average Rent:*\n"
    for apt_type, price in data['avg_rent'].items():
        response += f"• {apt_type.upper()}: {price}\n"
    
    # Websites
    response += "\n🌐 *Search Websites:*\n"
    for site in data['websites'][:4]:
        response += f"• {site}\n"
    
    # Tips
    response += "\n💡 *Tips:*\n"
    for tip in data['tips'][:4]:
        response += f"• {tip}\n"
    
    # Key phrases
    response += "\n📝 *Useful Phrases:*\n"
    for key, phrase in list(data['phrases'].items())[:5]:
        response += f"• {phrase}\n"
    
    response += "\n💬 Need help with a specific area or budget?"
    
    return response


